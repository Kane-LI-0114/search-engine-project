<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CSIT5930 Search Engine</display-name>
    <description>HKUST CSIT5930 Web Search Engine Project</description>

    <!-- Search Servlet Configuration -->
    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>search.web.SearchServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>SearchServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Enhancement 2: Keyword Browse Servlet -->
    <servlet>
        <servlet-name>KeywordBrowseServlet</servlet-name>
        <servlet-class>search.web.KeywordBrowseServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>KeywordBrowseServlet</servlet-name>
        <url-pattern>/keywords</url-pattern>
    </servlet-mapping>

    <!-- Enhancement 3: Autocomplete Suggest Servlet -->
    <servlet>
        <servlet-name>SuggestServlet</servlet-name>
        <servlet-class>search.web.SuggestServlet</servlet-class>
        <load-on-startup>3</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>SuggestServlet</servlet-name>
        <url-pattern>/suggest</url-pattern>
    </servlet-mapping>
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>search.web.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
</web-app>
